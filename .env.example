# ====================
# DATABASE CONFIGURATION
# ====================
DATABASE_URL=postgresql://username:password@localhost:5432/churn_ltv_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=churn_ltv_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ====================
# APPLICATION CONFIGURATION
# ====================
APP_NAME=AI Customer Churn & LTV Predictor
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ====================
# API CONFIGURATION
# ====================
API_V1_PREFIX=/api/v1
API_PORT=8000
HOST=0.0.0.0
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ====================
# ML MODEL CONFIGURATION
# ====================
MODEL_PATH=./backend/data/models/
CHURN_MODEL_PATH=./backend/data/models/churn_model.pkl
SEGMENTATION_MODEL_PATH=./backend/data/models/segmentation_model.pkl
LTV_MODEL_PATH=./backend/data/models/ltv_model.pkl

# ====================
# REDIS CONFIGURATION (Optional)
# ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ====================
# GEMINI AI API (For advanced features)
# ====================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# ====================
# CORS SETTINGS
# ====================
ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOW_CREDENTIALS=True
ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin,X-Requested-With

# ====================
# SECURITY SETTINGS
# ====================
PASSWORD_HASH_ALGORITHM=bcrypt
SALT_ROUNDS=12
SESSION_TIMEOUT=3600

# ====================
# FILE UPLOAD SETTINGS
# ====================
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=.csv,.xlsx,.json

# ====================
# EMAIL SETTINGS (Optional)
# ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ====================
# RATE LIMITING
# ====================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # seconds

# ====================
# CACHING
# ====================
CACHE_TTL=300  # 5 minutes
CACHE_MAX_SIZE=1000

# ====================
# LOGGING
# ====================
LOG_FILE_PATH=./backend/logs/app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_ROTATION_WHEN=m
LOG_ROTATION_INTERVAL=1
LOG_BACKUP_COUNT=7